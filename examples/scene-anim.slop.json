        "script": "local t, d = ...\nlocal pop = anim.out_back(anim.clamp(t / 0.55, 0, 1))\nlocal W = (frame and frame.w) or 1920\nlocal n = box{ growx = true, growy = true, kids = {\n  widgets.rays(t, { count = 22, spin = 0.5, burst = 1.6, color = { 255, 242, 214, 225 } }),\n  image{ asset = d.image, w = math.floor(W * 0.42), aspect = true, glow = 0.55, radius = 14, sc = pop, float = \"c\", z = 4 } } }\nn.ox, n.oy = anim.shake(t, 20, 0.4)\nreturn n",
