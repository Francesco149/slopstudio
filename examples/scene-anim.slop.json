        "data": {
          "title": "std.lua — widgets.reveal",
          "lang": "lua",
          "hi": 4,
          "step": 0.16,
          "lines": [
            "function widgets.reveal(t, d)",
            "  local e = anim.out_expo(t / dur)   -- friction stop",
            "  local dx = (d.dx or -460) * (1 - e)",
            "  return image{ tx = dx, glow = 0.85 }",
            "end"
          ]
        },
