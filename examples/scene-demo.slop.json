{
  "schema": "slopstudio.project/1",
  "meta": {
    "title": "scene clip demo — the Lua layout engine",
    "fps": 60,
    "resolution": [1920, 1080],
    "bg": "checker",
    "notes": "Self-demo for docs/LAYOUT_ENGINE.md: two `scene` clips (a reflowable quote card and a count-up stat), each a Lua script over the forkable presets/lua/std.lua stdlib. Transparent, sits on the checker. Render: build/slopstudio.exe examples/scene-demo.slop.json --shot out.png --time 1.5"
  },
  "assets": {},
  "tracks": [
    { "id": "tk_v", "name": "Video", "kind": "video", "rows": ["r_scene"] }
  ],
  "rows": {
    "r_scene": { "type": "scene", "name": "Scene", "params": {}, "clips": ["sc_quote", "sc_stat", "sc_doc", "sc_lineage", "sc_compare"] }
  },
  "clips": {
    "sc_quote": {
      "row": "r_scene", "start": 0.0, "dur": 4.0,
      "params": {
        "script": "local t, d = ...\nreturn widgets.quote(t, { text = d.text, cite = d.cite })",
        "data": {
          "text": "The best way to predict the future is to invent it.",
          "cite": "a reflowable, transparent, native quote card"
        }
      },
      "transform": { "pos": [0, 0], "scale": [1, 1], "rot": 0, "opacity": 1, "anchor": [0.5, 0.5] },
      "keyframes": {}
    },
    "sc_stat": {
      "row": "r_scene", "start": 4.0, "dur": 4.0,
      "params": {
        "script": "local t, d = ...\nreturn widgets.stat(t, { to = d.to, label = d.label, dur = 1.4 })",
        "data": { "to": 100, "label": "percent native — no baked PNG" }
      },
      "transform": { "pos": [0, 0], "scale": [1, 1], "rot": 0, "opacity": 1, "anchor": [0.5, 0.5] },
      "keyframes": {}
    },
    "sc_doc": {
      "row": "r_scene", "start": 8.0, "dur": 9.5,
      "params": {
        "script": "local t, d = ...\nreturn widgets.document(t, d)",
        "data": {
          "image": "docs/hero/editor.png",
          "source": "docs/hero/editor.png",
          "trans": 0.9,
          "excerpts": [
            { "rect": [0.01, 0.02, 0.30, 0.30], "hold": 2.2, "tr": "The Media browser — every generated asset and bed, one drag onto the timeline." },
            { "rect": [0.36, 0.10, 0.42, 0.42], "hold": 2.2, "tr": "The live preview: the compositor draws the frame at the playhead, instantly." },
            { "rect": [0.20, 0.58, 0.42, 0.42], "hold": 2.4, "tr": "The timeline — each row is one generation pipeline." }
          ]
        }
      },
      "transform": { "pos": [0, 0], "scale": [1, 1], "rot": 0, "opacity": 1, "anchor": [0.5, 0.5] },
      "keyframes": {}
    },
    "sc_lineage": {
      "row": "r_scene", "start": 17.5, "dur": 4.0,
      "params": {
        "script": "local t, d = ...\nreturn widgets.lineage(t, d)",
        "data": { "title": "how a scene renders", "nodes": ["Lua script", "table tree", "Clay layout", "ImDrawList"] }
      },
      "transform": { "pos": [0, 0], "scale": [1, 1], "rot": 0, "opacity": 1, "anchor": [0.5, 0.5] },
      "keyframes": {}
    },
    "sc_compare": {
      "row": "r_scene", "start": 21.5, "dur": 4.0,
      "params": {
        "script": "local t, d = ...\nreturn widgets.comparison(t, d)",
        "data": {
          "title": "native visuals, all reflowable",
          "items": [
            { "image": "docs/hero/code-card.png", "label": "code card" },
            { "image": "docs/hero/diagram.png", "label": "diagram" },
            { "image": "docs/hero/footage.png", "label": "footage inset" }
          ]
        }
      },
      "transform": { "pos": [0, 0], "scale": [1, 1], "rot": 0, "opacity": 1, "anchor": [0.5, 0.5] },
      "keyframes": {}
    }
  }
}
